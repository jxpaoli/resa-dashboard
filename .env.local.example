# Copie ce fichier en .env.local (local) et mets les mêmes dans Cloudflare Pages.
# Sans les variables Supabase → l'app tourne en mode mock (localStorage).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ID=

# Notifications push (clé VAPID publique — pas secrète).
# La clé VAPID *privée* va dans les secrets de l'Edge Function, jamais ici.
VITE_VAPID_PUBLIC_KEY=
